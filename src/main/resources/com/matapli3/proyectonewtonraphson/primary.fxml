<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.matapli3.proyectonewtonraphson.PrimaryController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #1e1e2e;">

    <!-- PANEL IZQUIERDO -->
    <left>
        <VBox spacing="10" style="-fx-padding: 20; -fx-pref-width: 270; -fx-background-color: #181825;">

            <Label text="Newton-Raphson"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #89dceb;"/>

            <Separator style="-fx-background-color: #45475a;"/>

            <Label text="f(x):" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtFx" promptText="Ej: x^2-x-2"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <Label text="Valor inicial x₀:" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtX0" promptText="Ej: 1.5"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <Label text="Número de iteraciones:" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtIteraciones" promptText="Ej: 10"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <Label text="Tolerancia (error):" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtTolerancia" promptText="Ej: 0.0001"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <Separator style="-fx-background-color: #45475a;"/>

            <!-- Botón Calcular con defaultButton="true" -->
            <Button fx:id="btnCalcular" text="Calcular" onAction="#calcular" defaultButton="true" maxWidth="Infinity"
                    style="-fx-background-color: #40b486; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 6; -fx-cursor: hand;"/>

            <Button fx:id="btnLimpiar" text="Limpiar" onAction="#limpiar" maxWidth="Infinity"
                    style="-fx-background-color: #45475a; -fx-text-fill: #cdd6f4; -fx-background-radius: 6; -fx-cursor: hand;"/>

            <Separator style="-fx-background-color: #45475a;"/>

            <Label text="Raíz Aproximada:" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtRaizAprox" editable="false"
                       style="-fx-background-color: #313244; -fx-text-fill: #a6e3a1; -fx-font-weight: bold; -fx-border-color: #40b486; -fx-border-radius: 4; -fx-background-radius: 4;"/>

            <Label text="¿Convergió?:" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtConverge" editable="false"
                       style="-fx-background-color: #313244; -fx-text-fill: #89dceb; -fx-border-color: #45475a; -fx-border-radius: 4; -fx-background-radius: 4;"/>

        </VBox>
    </left>

    <!-- PANEL DERECHO -->
    <center>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #1e1e2e;">

            <!-- Espacio gráfica -->
            <StackPane fx:id="panelGrafica"
                       style="-fx-border-color: #45475a; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-color: #181825; -fx-background-radius: 6; -fx-min-height: 300;"
                       VBox.vgrow="ALWAYS">
                <Label text="[ Gráfica - pendiente ]"
                       style="-fx-text-fill: #45475a; -fx-font-size: 16;"/>
            </StackPane>

            <!-- Tabla -->
            <Label text="Tabla de iteraciones:"
                   style="-fx-font-weight: bold; -fx-text-fill: #89dceb; -fx-font-size: 13;"/>
            <TableView fx:id="tablaIteraciones" prefHeight="220" VBox.vgrow="NEVER"
                       style="-fx-background-color: #181825; -fx-border-color: #45475a; -fx-border-radius: 6;">
                <columns>
                    <TableColumn fx:id="colN"     text="N°"    prefWidth="45"/>
                    <TableColumn fx:id="colXi"    text="xi"    prefWidth="110"/>
                    <TableColumn fx:id="colFx"    text="f(x)"  prefWidth="110"/>
                    <TableColumn fx:id="colFpx"   text="f'(x)" prefWidth="110"/>
                    <TableColumn fx:id="colXi1"   text="xi+1"  prefWidth="110"/>
                    <TableColumn fx:id="colDelta" text="δ"     prefWidth="110"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>
